   "source": [
    "x = int(input())\n",
    "c = 0\n",
    "i = 1\n",
    "while i <= x/2:\n",
    "    if x%i == 0:\n",
    "        c = c+1\n",
    "    i = i +1\n",
    "if c == 1:\n",
    "    print(\"prime\")\n",
    "else:\n",
    "    print(\"composite\")"
   ]
